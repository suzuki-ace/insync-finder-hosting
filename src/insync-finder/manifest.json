{
  "manifest_version": 3,
  "name": "Insync Finder",
  "version": "1.2",
  "description": "Google DriveのURLから、Insyncが同期するローカルファイルを既定アプリで開く/Finderで表示する。",
  "key": "",
  "permissions": ["nativeMessaging", "contextMenus", "tabs"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Insync: このファイルを既定アプリで開く",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
